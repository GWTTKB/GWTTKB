name: Build Consensus Rankings

on:
  repository_dispatch:
    types: [build-consensus]
  schedule:
    - cron: '0 7 * * *'  # 2am ET = 7am UTC
  workflow_dispatch:
    inputs:
      run_historical_import:
        description: 'Run historical import (only needed once)'
        required: false
        default: 'false'
        type: boolean

permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest
    timeout-minutes: 90

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4
        with:
          token: ${{ secrets.GITHUB_TOKEN }}

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Run historical import (one-time setup)
        if: ${{ github.event.inputs.run_historical_import == 'true' }}
        run: node scripts/import-historical.mjs

      - name: Build consensus rankings
        # PAUSED - consensus is manually maintained, do not overwrite
        # run: node scripts/build-consensus.mjs
        run: echo "Consensus build paused - manually maintained"

      - name: Build NFL stats (season + weekly data)
        run: node scripts/build-nfl-stats.mjs

      - name: Build analytics engine (correlations + comps + trajectories)
        run: node scripts/build-analytics.mjs

      - name: Build depth charts + target share redistribution
        run: node scripts/build-depth-charts.mjs

      - name: Build college stats + draft capital + combine (NFLverse + CFBD API)
        run: node scripts/build-college-stats.mjs
        env:
          CFBD_API_KEY: ${{ secrets.CFBD_API_KEY }}

      # Coaching staff is sourced from nfl-team-context.json (user's authoritative file)
      # Wikipedia scraper disabled — was producing wrong 2026 data
      # coaching-staff.json is rebuilt in build-depth-charts.mjs from team context

      - name: Build startup + rookie ADP (live Sleeper drafts)
        run: node scripts/build-startup-adp.mjs

      - name: Build market intelligence (trade trends, waiver signals)
        run: node scripts/build-market-intel.mjs

      - name: Commit updated data
        run: |
          git config user.name "GWTTKB Bot"
          git config user.email "bot@gwttkb.com"
          git add public/data/ || true
          git diff --staged --quiet || git commit -m "chore: update rankings + data $(date +%Y-%m-%d)"
          git push
