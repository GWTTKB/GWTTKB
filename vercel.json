{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=utf-8" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/stats(.*)", "dest": "/api/stats.js" },
    { "src": "/api/consensus(.*)", "dest": "/api/consensus.js" },
    { "src": "/data/(.*)", "dest": "/public/data/$1" },
    { "src": "/(.*)\\.html", "dest": "/public/$1.html" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "crons": [
    { "path": "/api/consensus", "schedule": "0 7 * * *" }
  ]
}
